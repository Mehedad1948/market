generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  GOOGLE
  TELEGRAM
  SMS
}

enum OtpPurpose {
  LOGIN
  VERIFY_PHONE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  EXPIRED
  CANCELED
  PENDING
}

enum PaymentTransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
}

model Symbol {
  id             String   @id @default(uuid())
  symbol         String   @unique
  name           String?
  isin           String?
  tsetmcId       String?
  sectorId       String?
  sectorName     String?
  displaySector  String?
  instrumentType String   @default("UNKNOWN")
  isActive       Boolean  @default(true)
  rawJson        Json?
  lastSeenAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sectorId])
  @@index([sectorName])
  @@index([instrumentType])
  @@index([isActive])
}

model Sector {
  id          String   @id
  name        String
  displayName String?
  slug        String?  @unique
  sortOrder   Int      @default(999)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SymbolDailyMetric {
  id                      String   @id @default(uuid())
  symbol                  String
  date                    String
  time                    String?
  tradeCount              BigInt?
  tradeVolume             Decimal? @db.Decimal(30, 4)
  tradeValue              Decimal? @db.Decimal(30, 4)
  priceMin                Decimal? @db.Decimal(30, 4)
  priceMax                Decimal? @db.Decimal(30, 4)
  priceYesterday          Decimal? @db.Decimal(30, 4)
  priceFirst              Decimal? @db.Decimal(30, 4)
  priceLast               Decimal? @db.Decimal(30, 4)
  priceLastChange         Decimal? @db.Decimal(30, 4)
  priceLastChangePercent  Decimal? @db.Decimal(30, 8)
  closePrice              Decimal? @db.Decimal(30, 4)
  closePriceChange        Decimal? @db.Decimal(30, 4)
  closePriceChangePercent Decimal? @db.Decimal(30, 8)
  rawJson                 Json
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([symbol, date])
  @@index([symbol, date])
}

model SymbolRealLegalDaily {
  id                  String   @id @default(uuid())
  symbol              String
  date                String
  buyCountIndividual  BigInt?
  buyCountLegal       BigInt?
  sellCountIndividual BigInt?
  sellCountLegal      BigInt?
  buyVolumeIndividual Decimal? @db.Decimal(30, 4)
  buyVolumeLegal      Decimal? @db.Decimal(30, 4)
  sellVolumeIndividual Decimal? @db.Decimal(30, 4)
  sellVolumeLegal     Decimal? @db.Decimal(30, 4)
  buyValueIndividual  Decimal? @db.Decimal(30, 4)
  sellValueIndividual Decimal? @db.Decimal(30, 4)
  rawJson             Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([symbol, date])
  @@index([symbol, date])
}

model AnalysisCache {
  id             String   @id @default(uuid())
  symbol         String
  paramsHash     String
  latestDataDate String
  action         String?
  score          Int?
  bias           String?
  entryTiming    String?
  latestClosePrice Decimal? @db.Decimal(30, 4)
  latestClosePriceChangePercent Decimal? @db.Decimal(30, 8)
  result         Json
  analyzedAt     DateTime @default(now())
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([symbol, paramsHash, latestDataDate])
  @@index([symbol, expiresAt])
  @@index([paramsHash, analyzedAt])
  @@index([paramsHash, action, score])
  @@index([expiresAt])
}

model AnalysisRequest {
  id         String   @id @default(uuid())
  symbol     String
  params     Json
  cacheHit   Boolean
  dataSource String
  status     String
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([symbol, createdAt])
}

model BacktestRun {
  id            String   @id @default(uuid())
  status        String   @default("RUNNING")
  paramsHash    String
  params        Json
  scoringVersion Int
  horizons      Json
  symbols       Json
  symbolCount   Int      @default(0)
  snapshotCount Int      @default(0)
  skippedCount  Int      @default(0)
  errorCount    Int      @default(0)
  errors        Json?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots BacktestSignalSnapshot[]

  @@index([status, startedAt])
  @@index([paramsHash, scoringVersion, startedAt])
}

model BacktestSignalSnapshot {
  id             String      @id @default(uuid())
  runId          String
  run            BacktestRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  symbol         String
  asOfDate       String
  sectorId       String?
  sectorName     String?
  latestClosePrice Decimal? @db.Decimal(30, 4)

  compositeAction      String
  compositeScore       Int
  compositeBias        String
  compositeEntryTiming String

  shortAction              String
  shortScore               Int
  shortQuality             String
  shortForNewPosition      String
  shortForExistingPosition String
  midAction                String
  midScore                 Int
  midQuality               String
  midForNewPosition        String
  midForExistingPosition   String
  longAction               String
  longScore                Int
  longQuality              String
  longForNewPosition       String
  longForExistingPosition  String

  atrVolatilityRegime String
  relativeTradeValue20 Decimal? @db.Decimal(30, 8)
  liquidityBucket      String

  forwardReturn1d  Decimal? @db.Decimal(30, 8)
  forwardReturn5d  Decimal? @db.Decimal(30, 8)
  forwardReturn20d Decimal? @db.Decimal(30, 8)
  forwardReturn60d Decimal? @db.Decimal(30, 8)
  maxDrawdown1d    Decimal? @db.Decimal(30, 8)
  maxDrawdown5d    Decimal? @db.Decimal(30, 8)
  maxDrawdown20d   Decimal? @db.Decimal(30, 8)
  maxDrawdown60d   Decimal? @db.Decimal(30, 8)

  createdAt DateTime @default(now())

  @@unique([runId, symbol, asOfDate])
  @@index([runId, compositeAction])
  @@index([runId, asOfDate])
  @@index([runId, sectorName])
  @@index([runId, liquidityBucket])
  @@index([runId, atrVolatilityRegime])
  @@index([runId, shortForNewPosition])
  @@index([runId, shortForExistingPosition])
  @@index([runId, midForNewPosition])
  @@index([runId, midForExistingPosition])
  @@index([runId, longForNewPosition])
  @@index([runId, longForExistingPosition])
}

model User {
  id               String              @id @default(uuid())
  displayName      String?
  firstName        String?
  lastName         String?
  email            String?             @unique
  phone            String?             @unique
  avatarUrl        String?
  telegramUserId   String?             @unique
  telegramUsername String?
  isActive         Boolean             @default(true)
  trialUsed        Boolean             @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  authAccounts     UserAuthAccount[]
  sessions         UserSession[]
  otpCodes         OtpCode[]
  subscriptions    Subscription[]
  payments         PaymentTransaction[]
  watchlist        UserWatchlistItem[]
  portfolios       Portfolio[]
}

model UserAuthAccount {
  id                String       @id @default(uuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  providerEmail     String?
  providerPhone     String?
  metadata          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model UserSession {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt])
}

model OtpCode {
  id          String     @id @default(uuid())
  userId      String?
  targetPhone String
  codeHash    String
  purpose     OtpPurpose
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime   @default(now())
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([targetPhone, expiresAt])
  @@index([userId, createdAt])
}

model Plan {
  id            String         @id @default(uuid())
  code          String         @unique
  name          String
  description   String?
  durationDays  Int
  priceAmount   Decimal?       @db.Decimal(18, 2)
  currency      String?
  isTrial       Boolean        @default(false)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id               String               @id @default(uuid())
  userId           String
  planId           String
  status           SubscriptionStatus
  startsAt         DateTime
  endsAt           DateTime
  canceledAt       DateTime?
  paymentProvider  String?
  paymentReference String?
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             Plan                 @relation(fields: [planId], references: [id])
  payments         PaymentTransaction[]

  @@index([userId, status, endsAt])
  @@index([planId])
  @@index([status, endsAt])
}

model PaymentTransaction {
  id             String                   @id @default(uuid())
  userId         String
  subscriptionId String?
  provider       String
  reference      String
  status         PaymentTransactionStatus
  amount         Decimal                  @db.Decimal(18, 2)
  currency       String
  payload        Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription?            @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([provider, reference])
  @@index([userId, createdAt])
  @@index([subscriptionId])
}

model UserWatchlistItem {
  id        String   @id @default(uuid())
  userId    String
  symbol    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([symbol])
}

model Portfolio {
  id        String             @id @default(uuid())
  userId    String
  name      String             @default("Default")
  isDefault Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings  PortfolioHolding[]

  @@index([userId])
  @@index([userId, isDefault])
}

model PortfolioHolding {
  id              String    @id @default(uuid())
  portfolioId     String
  symbol          String
  quantity        Decimal   @db.Decimal(30, 4)
  averageBuyPrice Decimal?  @db.Decimal(30, 4)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol])
  @@index([symbol])
}
